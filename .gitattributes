# Normalize all text files to LF in the repo.
# Git will still check them out with the platform-native line ending
# if the user's core.autocrlf is set, but the blob stored in Git
# is always LF — that matches Cloudflare Pages / GitHub / Linux CI.
* text=auto eol=lf

# Explicit: known text types stay LF
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.json   text eol=lf
*.xml    text eol=lf
*.svg    text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.txt    text eol=lf
*.sh     text eol=lf

# Binary files — never touch
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.webp   binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.pdf    binary
